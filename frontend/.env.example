# Base URL of the MPF CRM backend API (include the version prefix)
#
# LOCAL (direct to backend):
#   NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1
#
# PRODUCTION (recommended — same-origin proxy via next.config rewrites):
#   NEXT_PUBLIC_API_URL=/api/v1
#   API_PROXY_TARGET=https://rmw-crm-1.onrender.com   # Vercel env only (not NEXT_PUBLIC)
#
# PRODUCTION (direct cross-origin — cookies often blocked by browsers):
#   NEXT_PUBLIC_API_URL=https://rmw-crm-1.onrender.com/api/v1
NEXT_PUBLIC_API_URL=/api/v1

# App metadata
NEXT_PUBLIC_APP_NAME=MPF CRM

# Firebase (Web app) — used for Google/Facebook sign-in
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
