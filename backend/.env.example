# ── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=http://localhost:3000

# ── Database (MySQL) ─────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=changeme
DB_NAME=mpf_crm
DB_CONNECTION_LIMIT=10

# ── JWT / Auth ───────────────────────────────────────────
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-another-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Cookie settings for the refresh token
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# ── Email (verification / reset) ─────────────────────────
# In dev, if SMTP is not set, emails are logged to console.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM="MPF CRM <no-reply@mypropertyfact.com>"
APP_URL=http://localhost:3000

# ── Seed super admin ─────────────────────────────────────
SEED_ADMIN_EMAIL=admin@mypropertyfact.com
SEED_ADMIN_PASSWORD=Admin@12345
SEED_ADMIN_NAME=MPF Super Admin

# ── OAuth (optional — future phase) ──────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Firebase Cloud Messaging (optional — future phase) ───
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# ── Firebase Auth (Admin SDK) ────────────────────────────
# Used by /auth/firebase to verify Firebase ID tokens.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# IMPORTANT: keep \n newlines (quoted string)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
