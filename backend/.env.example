# ── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1
# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=http://localhost:3000

# ── Database (MySQL) ─────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=changeme
# Must match the DB migrate creates (schema uses this via migrate.ts)
DB_NAME=RMW-CRM
DB_CONNECTION_LIMIT=10
# Required for Aiven / managed MySQL. Download CA from the provider console.
DB_SSL=false
DB_SSL_CA=ca.pem
# On Render: paste full ca.pem as ONE line with \n between lines, e.g.
# DB_CA_CERT="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----\n"
# Locally: leave unset and use DB_SSL_CA=ca.pem instead (dotenv breaks unquoted multiline).
DB_CA_CERT=

# ── JWT / Auth ───────────────────────────────────────────
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-another-long-random-string
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Cookie settings for the refresh token
# Leave COOKIE_DOMAIN empty when using the Vercel /api/v1 proxy (recommended).
COOKIE_DOMAIN=
COOKIE_SECURE=false
# lax = same-origin proxy (Vercel rewrite). none = direct cross-origin API only.
COOKIE_SAME_SITE=lax

# ── Email (verification / reset) ─────────────────────────
# In dev, if SMTP is not set, emails are logged to console.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM="MPF CRM <no-reply@mypropertyfact.com>"
APP_URL=http://localhost:3000

# ── Seed super admin ─────────────────────────────────────
SEED_ADMIN_EMAIL=admin@mypropertyfact.com
SEED_ADMIN_PASSWORD=Admin@12345
SEED_ADMIN_NAME=MPF Super Admin

# ── OAuth (optional — future phase) ──────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Firebase Cloud Messaging (optional — future phase) ───
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=

# ── My Property Fact integration ─────────────────────────
# Shared secret between MPF backend and CRM (webhook + export)
MPF_CRM_WEBHOOK_KEY=change-me-to-a-long-random-string
# MPF API base (used by CRM sync to pull existing enquiries)
MPF_API_URL=https://apis.mypropertyfact.in/api/v1
# Used by /auth/firebase to verify Firebase ID tokens.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# IMPORTANT: keep \n newlines (quoted string)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
